# URL Endpoint RPC Sepolia (Dapatkan gratis dari Alchemy / Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private Key dari MetaMask Wallet Deployer Anda (JANGAN GUNAKAN AKUN UTAMA)
# Cara ambil: MetaMask -> Account Details -> Show Private Key
PRIVATE_KEY=0x_taruh_private_key_metamask_anda_di_sini

# API Key Etherscan jika ingin melakukan verifikasi smart contract (opsional)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
